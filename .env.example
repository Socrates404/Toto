# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ─── Mode ────────────────────────────────────────────────────────────────────
# "debug"      → emails printed to console, SESSION_SECRET has a safe default
# "production" → all vars below are required, real emails sent
APP_MODE=debug

# ─── Database ────────────────────────────────────────────────────────────────
# Local PostgreSQL (Option B — see RUNNING_LOCALLY.md)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/toto

# ─── Session ─────────────────────────────────────────────────────────────────
# Required in production. In debug mode a default is applied if missing.
SESSION_SECRET=change-me-to-a-long-random-string

# ─── App URL ─────────────────────────────────────────────────────────────────
# Used in password-reset emails. Defaults to http://localhost:5000 in debug.
APP_URL=http://localhost:5000

# ─── Email (production only) ──────────────────────────────────────────────────
# Not needed in debug mode — reset links are printed to the console instead.
RESEND_API_KEY=

# ─── Admin ────────────────────────────────────────────────────────────────────
# The user ID that can trigger POST /api/photos/reset-cheating.
# Check your users table after first run: SELECT id, username FROM users;
ADMIN_USER_ID=
